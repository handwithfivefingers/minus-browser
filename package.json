{
  "name": "minusbrowser",
  "productName": "MinusBrowser",
  "appBundleId": "com.minusbrowser.localdev",
  "appId": "com.minusbrowser.localdev",
  "version": "0.4.1.1",
  "description": "Lightweight Browser, cross platform, built with Electron and Vite",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation\" --unhandled-rejections=strict electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:mac": "cross-env NODE_OPTIONS=\"--no-deprecation\" --unhandled-rejections=strict PLATFORM=MAC electron-forge make",
    "build:win": "cross-env NODE_OPTIONS=\"--no-deprecation\" --unhandled-rejections=strict PLATFORM=WIN electron-forge make",
    "publish": "electron-forge publish",
    "build:renderers": "node scripts/build-renderers.mjs",
    "lint": "eslint --ext .ts,.tsx ."
  },
  "repository": {
    "type": "git",
    "owner": "me",
    "name": "Minus Browser",
    "url": "https://github.com/handwithfivefingers/minus-browser"
  },
  "keywords": [],
  "author": {
    "name": "handwithfivefingers",
    "email": "truyenmv@flomail.net"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.8.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.8.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.1.11",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "electron": "^42.2.0",
    "eslint": "^8.57.1",
    "eslint-plugin-import": "^2.32.0",
    "typescript": "~4.5.4",
    "vite": "^5.4.19"
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.18.0",
