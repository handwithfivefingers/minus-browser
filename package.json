{
  "name": "minusbrowser",
  "productName": "MinusBrowser",
  "appBundleId": "com.minusbrowser.localdev",
  "appId": "com.minusbrowser.localdev",
  "version": "0.5.91",
  "description": "Lightweight Browser, cross platform, built with Electron and Vite",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=\"--no-deprecation\" --unhandled-rejections=strict electron-forge start -- --force",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build:mac": "cross-env NODE_OPTIONS=\"--no-deprecation\" --unhandled-rejections=strict PLATFORM=MAC electron-forge make",
    "build:win": "cross-env NODE_OPTIONS=\"--no-deprecation\" --unhandled-rejections=strict PLATFORM=WIN electron-forge make",
    "publish": "electron-forge publish",
    "build:renderers": "node scripts/build-renderers.mjs",
    "format": "prettier --write \".\"",
    "lint": "eslint --ext .ts,.tsx,.js,.jsx .",
    "lint:main": "eslint --ext .ts,.js src/main src/preload src/features",
    "lint:renderer": "eslint --ext .ts,.tsx,.js,.jsx src/renderer",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "owner": "me",
    "name": "Minus Browser",
    "url": "https://github.com/handwithfivefingers/minus-browser"
  },
  "keywords": [],
  "author": {
    "name": "handwithfivefingers",
    "email": "truyenmv@flomail.net"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-dmg": "^7.8.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.8.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@electron/rebuild": "^4.2.0",
    "@tailwindcss/vite": "^4.1.11",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/prismjs": "^1.26.6",
    "@types/react": "^19.1.9",
    "@types/react-dom": "^19.1.7",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitest/coverage-v8": "4.1.10",
    "electron": "42.2.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^2.7.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "~4.5.4",
    "vite": "^5.4.19",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@ghostery/adblocker": "^2.18.0",
    "@hookform/resolvers": "^5.4.0",
    "@tabler/icons-react": "^3.34.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "cross-fetch": "^4.1.0",
    "electron-findbar": "^3.7.2",
    "electron-log": "^5.4.2",
    "electron-squirrel-startup": "^1.0.1",
    "fuse.js": "^7.4.2",
    "motion": "^12.42.2",
    "openai": "^6.43.0",
    "parse-domain": "^8.3.0",
    "prismjs": "^1.30.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.81.0",
    "react-markdown": "^10.1.0",
    "react-router": "^7.7.1",
    "react-simple-code-editor": "^0.14.1",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.11",
    "update-electron-app": "^3.2.0",
    "uuid": "^11.1.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.8"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
